# Copy to .env.local for local development. Never commit the filled-in file.
# In production these live in Vercel: Project Settings -> Environment Variables.
#
# Note there is no NEXT_PUBLIC_ prefix anywhere in this file, and there must
# never be: that prefix inlines a value into the JavaScript bundle, which would
# hand the Gemini key to anyone who opens the app.

# From https://aistudio.google.com/apikey
GEMINI_API_KEY=

# The Apps Script web app deployment URL (ends in /exec).
APPS_SCRIPT_URL=

# Must match the SHARED_SECRET script property on the Apps Script side.
# Generate with: openssl rand -hex 24
APPS_SCRIPT_SECRET=

# What you type on the app's unlock screen.
APP_PASSCODE=

# Signs the session cookie. Any long random string.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
